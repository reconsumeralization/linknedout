{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm -s exec tsc -p tsconfig.json --noEmit",
    "analyze": "ANALYZE=true next build",
    "supabase:local:start": "powershell -ExecutionPolicy Bypass -File scripts/supabase-local.ps1 -Action start",
    "supabase:local:stop": "powershell -ExecutionPolicy Bypass -File scripts/supabase-local.ps1 -Action stop",
    "supabase:local:reset": "powershell -ExecutionPolicy Bypass -File scripts/supabase-local.ps1 -Action reset",
    "supabase:local:status": "powershell -ExecutionPolicy Bypass -File scripts/supabase-local.ps1 -Action status",
    "supabase:local:env": "powershell -ExecutionPolicy Bypass -File scripts/supabase-local.ps1 -Action env",
    "supabase:local:test-user": "powershell -ExecutionPolicy Bypass -File scripts/supabase-local-test-user.ps1",
    "supabase:db:start": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action start",
    "supabase:db:stop": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action stop",
    "supabase:db:reset": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action reset",
    "supabase:db:status": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action status",
    "supabase:db:logs": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action logs",
    "supabase:db:env": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action env",
    "supabase:db:psql": "powershell -ExecutionPolicy Bypass -File scripts/supabase-db-container.ps1 -Action psql",
    "supabase:branded:doctor": "powershell -ExecutionPolicy Bypass -File scripts/branded-supabase-doctor.ps1",
    "supabase:branded:sync-env": "powershell -ExecutionPolicy Bypass -File scripts/branded-supabase-doctor.ps1 -SyncAppEnv",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build --remove-orphans",
    "docker:down": "docker compose down --remove-orphans",
    "docker:reset": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs -f app db",
    "docker:status": "docker compose ps",
    "local:up": "pnpm -s supabase:local:start && pnpm -s supabase:local:reset && pnpm -s supabase:local:test-user",
    "local:check": "pnpm -s smoke:auth:skipbuild",
    "local:down": "pnpm -s supabase:local:stop",
    "smoke:auth": "powershell -ExecutionPolicy Bypass -File scripts/smoke-auth.ps1",
    "smoke:auth:skipbuild": "powershell -ExecutionPolicy Bypass -File scripts/smoke-auth.ps1 -SkipBuild",
    "smoke:sentinel:drill": "powershell -ExecutionPolicy Bypass -File scripts/sentinel-incident-drill.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:patterns:update": "node scripts/update-security-patterns-from-openai.js",
    "docker:onboard": "powershell -ExecutionPolicy Bypass -File scripts/docker-local-onboard.ps1",
    "local:full:onboard": "powershell -ExecutionPolicy Bypass -File scripts/local-docker-full-onboard.ps1",
    "local:full:onboard:skip-docker": "powershell -ExecutionPolicy Bypass -File scripts/local-docker-full-onboard.ps1 -SkipDocker",
    "local:full:onboard:skip-supabase": "powershell -ExecutionPolicy Bypass -File scripts/local-docker-full-onboard.ps1 -SkipSupabase",
    "sentinel:cron:invoke": "node scripts/sentinel-cron-invoke.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@ai-sdk/react": "^1.2.12",
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.10",
    "@deck.gl/layers": "^9.2.10",
    "@deck.gl/react": "^9.2.10",
    "@hookform/resolvers": "^3.9.1",
