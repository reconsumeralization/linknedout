{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "DB Container",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["supabase:db:start"],
      "port": 54322
    },
    {
      "name": "Docker (DB + App)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 3000
    }
  ]
}
