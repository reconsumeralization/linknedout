# =============================================================================
# LinkedOut – environment variables (example)
#
# Copy to .env.local and fill in real values.
# ⚠ Never commit .env.local or any file containing real secrets.
# ⚠ Never use placeholder values (your-*, sk-...) in a running environment.
#    The app will not work correctly with placeholder values.
#
# Generate strong random secrets with:
#   openssl rand -base64 32     # general secrets / passwords
#   openssl rand -hex 32        # hex keys (e.g. EMAIL_TOKEN_ENCRYPTION_KEY)
# =============================================================================

# --- Required: Local / Docker database password ───────────────────────────────
# Used by docker-compose and pnpm supabase:db:* scripts.
# Generate: openssl rand -base64 32
# The scripts/supabase-db-container.ps1 will auto-generate this on first run
# if it is missing — but set it explicitly for consistent environments.
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32

# --- Required: Supabase (auth + DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Required for server-side Supabase (e.g. service role) ---
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Required for AI features (chat, realtime) ---
OPENAI_API_KEY=sk-...

# --- Optional: App URL and CORS ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production, set to your exact app origin (e.g. https://app.example.com) to restrict CORS.
# Do not use * for protected APIs; chat, MCP, and realtime use this when set.
CORS_ALLOWED_ORIGIN=

# --- Optional: Auth toggles (default: required in production) ---
# CHAT_REQUIRE_AUTH=true
# REALTIME_REQUIRE_AUTH=true

# --- Optional: Email (Gmail / Outlook OAuth) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=

# --- Optional: LinkedIn Consumer Solutions (Sign In + Share) ---
# Create an app at https://www.linkedin.com/developers/apps
# Scopes: openid profile email (Sign In); w_member_social (Share on LinkedIn).
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/oauth?action=callback
# LINKEDIN_OAUTH_RATE_LIMIT_MAX=30
# LINKEDIN_OAUTH_RATE_LIMIT_WINDOW_MS=60000
# Table for stored identities (default: linkedin_identities). RLS: user_id = auth.uid().
# SUPABASE_LINKEDIN_IDENTITIES_TABLE=linkedin_identities

# --- Optional: Email token encryption (for stored OAuth tokens) ---
# EMAIL_TOKEN_ENCRYPTION_KEY=32-byte-hex-or-base64-key

# --- Optional: Agent control plane cron (for scheduled jobs) ---
# AGENT_CONTROL_PLANE_CRON_SECRET=strong-random-secret

# --- Optional: Security pattern refresh feed (used by scripts/update-security-patterns.mjs / CI cron) ---
# SECURITY_PATTERNS_FEED_URL=
# SECURITY_PATTERNS_FEED_BEARER=
# SECURITY_PATTERNS_OPENAI_MODEL=gpt-4o-mini
# SECURITY_PATTERNS_INTERVAL_SECONDS=604800

# --- Optional: Realtime / OpenAI ---
# OPENAI_API_BASE_URL=
# OPENAI_REALTIME_MODEL=
# OPENAI_REALTIME_VOICE=
# OPENAI_REALTIME_EXPIRES_AFTER_SECONDS=600
# REALTIME_ALLOW_INSECURE_UPSTREAM=false
# REALTIME_ALLOW_PRIVATE_UPSTREAM_HOST=false

# --- Optional: Web tools hardening ---
# WEB_TOOLS_ALLOWED_DOMAINS=example.com,docs.example.com
# WEB_TOOLS_ENFORCE_DNS_REBINDING_PROTECTION=true
# WEB_TOOLS_DNS_LOOKUP_TIMEOUT_MS=2500

# --- Optional: MCP ---
# MCP_RESOURCE_URL=
# MCP_AUTHORIZATION_SERVERS=
# MCP_SCOPES_SUPPORTED=
# MCP_ENFORCE_SCOPES=
# MCP_ENFORCE_ISSUER=
# MCP_ENFORCE_AUDIENCE=
# When MCP_ENFORCE_TOOL_ALLOWLIST is true, list allowed tool names (e.g. webSearch,fetchPage,searchProfiles,...).
# MCP_ALLOWED_TOOLS=
# MCP_BLOCKED_TOOLS=
# MCP_ENFORCE_TOOL_ALLOWLIST=
# MCP_BLOCK_SUSPICIOUS_TOOL_ARGS=
# MCP_REQUIRE_PRIVILEGED_TOOL_APPROVAL=true
# MCP_PRIVILEGED_TOOLS=
# MCP_NON_PRIVILEGED_TOOLS=
# MCP_AUTO_CLASSIFY_PRIVILEGED_TOOLS=true
# MCP_CRITICAL_WORKFLOW_VERIFY_MODE=warn
# MCP_CRITICAL_WORKFLOW_VERIFY_WINDOW_SECONDS=120
# MCP_ENFORCE_DATA_EGRESS_DLP=true
# MCP_DATA_EGRESS_TOOLS=
# MCP_NON_DATA_EGRESS_TOOLS=
# MCP_AUTO_CLASSIFY_DATA_EGRESS_TOOLS=true
# MCP_ENFORCE_DATA_EGRESS_TOOL_ALLOWLIST=true
# MCP_EGRESS_SHAPE_APPROVAL_ENABLED=true
# MCP_EGRESS_APPROVAL_PAYLOAD_BYTES_THRESHOLD=65536
# MCP_EGRESS_APPROVAL_ATTACHMENT_COUNT_THRESHOLD=3
# MCP_EGRESS_APPROVAL_THREAD_MESSAGE_COUNT_THRESHOLD=10
# MCP_DATA_EGRESS_TOOL_ALLOWLIST=sendMessage,postContent
# MCP_DATA_EGRESS_TOOL_RATE_LIMIT_PER_MINUTE=20
# MCP_DATA_EGRESS_TOOL_RATE_LIMIT_WINDOW_MS=60000
# MCP_DATA_EGRESS_TOOL_RATE_LIMITS=sendMessage:5,postContent:2
# Production strict-mode: set MCP_ENFORCE_DATA_EGRESS_DLP=true for egress-DLP approval gate.

# --- Optional: Sentinel / AEGIS ---
# SENTINEL_MODE=shadow
# SENTINEL_APPROVAL_DEDUPE_WINDOW_MINUTES=10
# SENTINEL_APPROVAL_EXECUTION_WINDOW_MINUTES=120
# SENTINEL_ALERT_WEBHOOK_ENABLED=false
# SENTINEL_ALERT_WEBHOOK_URL=
# SENTINEL_ALERT_WEBHOOK_BEARER_TOKEN=
# SENTINEL_ALERT_WEBHOOK_TIMEOUT_MS=5000
# SENTINEL_ALERT_WEBHOOK_COOLDOWN_SECONDS=900
# SENTINEL_ALERT_KPI_TASK_REALITY_MISMATCH_THRESHOLD=1
# SENTINEL_ALERT_KPI_CRITICAL_VERIFICATION_MISSED_THRESHOLD=1
# SENTINEL_ALERT_KPI_UNRESOLVED_HIGH_RISK_EVENTS_THRESHOLD=5
# SENTINEL_ALERT_KPI_OPEN_INCIDENTS_THRESHOLD=3
# SENTINEL_ALERT_KPI_HIGH_SEVERITY_ANOMALY_THRESHOLD=1
# SENTINEL_ALERT_OWNER_LOOKBACK_HOURS=24
# SENTINEL_ALERT_MAX_OWNERS_PER_RUN=100
# SENTINEL_CRON_SECRET=
# SENTINEL_CRON_RATE_LIMIT_MAX=30
# SENTINEL_CRON_RATE_LIMIT_WINDOW_MS=60000
# AEGIS_ENABLED=true
# LLM_GUARD_ENABLED=true
# LLM_GUARD_ENFORCE=true
# LLM_GUARD_FAIL_CLOSED=false
# LLM_GUARD_MODEL=gpt-4o-mini
# LLM_GUARD_TIMEOUT_MS=6000
# LLM_GUARD_MAX_CONTEXT_CHARS=6000

# --- Optional: Supabase LLM DB tool hardening ---
# ENABLE_SUPABASE_LLM_DB_TOOLS=false
# SUPABASE_LLM_BLOCK_POISONED_DOCUMENTS=true
# SUPABASE_LLM_REQUIRE_TRUSTED_SOURCE_FOR_UPSERT=false
# SUPABASE_LLM_TRUSTED_SOURCES=wiki,notion,sharepoint
# SUPABASE_LLM_FILTER_UNTRUSTED_QUERY_RESULTS=true
# SUPABASE_LLM_REDACT_SENSITIVE_QUERY_FIELDS=true
# Production strict-mode: set SUPABASE_LLM_BLOCK_POISONED_DOCUMENTS=true, SUPABASE_LLM_FILTER_UNTRUSTED_QUERY_RESULTS=true, and define SUPABASE_LLM_TRUSTED_SOURCES (see docs/mcp-security-hardening.md).

# --- Optional: Logging and metrics ---
# LOG_ENDPOINT=
# ENABLE_REMOTE_LOGGING=false
# METRICS_API_KEY=

# --- Optional: 3D Globe ---
# The globe uses MapLibre + free tiles (CARTO / OSM); no token or credit card required.
# Optional: set NEXT_PUBLIC_MAPBOX_TOKEN if you later add Mapbox satellite imagery.
# NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Optional: Redis (for distributed rate limiting) ---
# When set, rate limits use Redis so multiple instances share the same counters.
# Leave unset to use in-memory rate limiting per instance.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:pass@host:6380

# --- Optional: Repo-managed DB-only container ---
# Populated by: pnpm supabase:db:start (or supabase:db:env)
# This is for SQL tooling/migrations only; app APIs still require full Supabase services.
# SUPABASE_DB_CONTAINER_URL=postgresql://postgres:<POSTGRES_PASSWORD>@127.0.0.1:54322/postgres
# SUPABASE_DB_CONTAINER_HOST=127.0.0.1
# SUPABASE_DB_CONTAINER_PORT=54322
# SUPABASE_DB_CONTAINER_USER=postgres
# SUPABASE_DB_CONTAINER_PASSWORD=<POSTGRES_PASSWORD>
# SUPABASE_DB_CONTAINER_DATABASE=postgres

# --- Optional: Body size and rate limits (see lib/request-body.ts, lib/request-rate-limit.ts) ---
# ABSOLUTE_MAX_BODY_BYTES=20000000
# Per-route limits use route-specific env var names.
