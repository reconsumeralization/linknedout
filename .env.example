# =============================================================================
# LinkedOut — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# OR skip this entirely — users can configure keys in Settings > Backend Configuration.
# For Vercel deployment, no env vars are required (users configure in-app).

# --- Supabase ---
# Option A: Cloud (https://supabase.com/dashboard/project/_/settings/api)
# Option B: Local Docker (run: ./scripts/setup-supabase.sh local)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- AI Providers (all optional — users can add in Settings) ---
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# GOOGLE_API_KEY=your-gemini-key
# MISTRAL_API_KEY=your-mistral-key
# GROQ_API_KEY=gsk_your-groq-key
# OLLAMA_URL=http://localhost:11434
# LOCAL_MODEL_URL=https://your-custom-endpoint/v1

# --- Email OAuth (Optional) ---
# Register these exact redirect URLs in Google Cloud Console / Azure App Registration.
# (The app defaults to these when the env vars are unset — they must match the provider.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/oauth?action=callback&provider=gmail

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/email/oauth?action=callback&provider=outlook

# --- LinkedIn OAuth (Optional) ---
# Must match the redirect URL in your LinkedIn Developer app (same pattern as code default).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/oauth?action=callback

# --- LinkedIn workflow panel (client; optional) ---
# demo = interactive UI with simulated runs (default). off = placeholder message only.
# NEXT_PUBLIC_LINKEDIN_WORKFLOWS_MODE=demo

# --- Data Sources (Optional) ---
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/linkedout
# MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/data-xxxxx/endpoint/data/v1
# MONGODB_DATA_API_KEY=your-atlas-data-api-key
# NOTION_API_KEY=ntn_your-key
# NOTION_WORKSPACE_ID=your-workspace-id
# NOTION_PROFILES_DB_ID=your-notion-profiles-database-id
# NOTION_TRIBES_DB_ID=your-notion-tribes-database-id
# NOTION_PROJECTS_DB_ID=your-notion-projects-database-id

# --- Vercel Marketplace Integrations (all optional — install in-app) ---
# Most IDs in the in-app catalog are registry-only until wired; see Marketplace → Integrations tab.
# STRIPE_SECRET_KEY=sk_test_your-key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-secret
# SENTRY_DSN=https://your-dsn@sentry.io/123
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
# Optional; marketplace runner defaults to https://us.i.posthog.com if unset
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# PINECONE_API_KEY=
# PINECONE_INDEX=
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# RESEND_API_KEY=re_your-key
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_SIGNING_SECRET=
# XAI_API_KEY=
# FAL_KEY=
# DEEPINFRA_API_KEY=
# TOGETHER_API_KEY=
# REPLICATE_API_TOKEN=
# PERPLEXITY_API_KEY=
# ELEVENLABS_API_KEY=
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# ARCJET_KEY=

# --- Cron Job Secrets (required for Vercel Cron automation) ---
# CRON_SECRET=your-shared-cron-secret
# HEARTBEAT_CRON_SECRET=your-heartbeat-secret
# EVOLUTION_CRON_SECRET=your-evolution-secret
# SENTINEL_CRON_SECRET=your-sentinel-secret
# AGENT_CONTROL_PLANE_CRON_SECRET=your-agent-cron-secret

# --- Deployment ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
