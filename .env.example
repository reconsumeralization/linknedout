# =============================================================================
# LinkedOut — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these as Environment Variables in the dashboard

# --- Supabase (Required) ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Provider (Required - pick one) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Email OAuth (Optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/oauth/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/email/oauth/callback

# --- Deployment ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
